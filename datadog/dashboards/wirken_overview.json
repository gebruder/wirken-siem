{
  "title": "Wirken audit overview",
  "description": "Eight-detection dashboard for the Wirken audit feed. Each tile maps one-to-one to a saved detection.",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "**Wirken-SIEM detection overview**\n\n- Shell-driven outbound fetch (Detection 1)\n- Exec fork pairing (Detection 2)\n- Binary write (Detection 3)\n- Skill-dir-resident binary (Detection 4)\n- Chain tamper (Detection 5)\n- MCP entry refused (Detection 6)\n- Veto hook denied or timed out (Detection 7)\n- Tool output redacted (Detection 8)",
        "background_color": "yellow",
        "font_size": "14",
        "text_align": "left",
        "show_tick": false
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Shell outbound fetch (Detection 1)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.kind:assistant_tool_calls @wirken.event.calls.name:exec (@argv_first:curl OR @argv_first:wget OR @argv_first:msiexec OR @argv_first:invoke-webrequest OR @argv_first:iwr OR @argv_first:bitsadmin OR @argv_first:certutil)"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Long-running exec (Detection 2)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.kind:tool_result @wirken.event.tool_name:exec @exec_duration_ms:>30000"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Binary write (Detection 3)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.kind:assistant_tool_calls @wirken.event.calls.name:write_file @write_file_extension:*"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Skill-dir exec (Detection 4)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.kind:assistant_tool_calls @wirken.event.calls.name:exec @argv_skill_dir_match:true"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Chain tamper (Detection 5)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.action:audit.chain_broken"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "MCP entry refused (Detection 6)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.kind:mcp_entry_refused"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Veto hook deny or timeout (Detection 7)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.kind:hook_dispatched (@wirken.event.decision.kind:deny OR @wirken.event.decision.kind:timeout)"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Tool output redacted (Detection 8)",
        "requests": [
          {
            "response_format": "timeseries",
            "queries": [
              {
                "data_source": "logs",
                "name": "query1",
                "indexes": ["main"],
                "compute": {"aggregation": "count"},
                "search": {
                  "query": "@ddsource:wirken @wirken.kind:tool_output_redacted"
                }
              }
            ],
            "display_type": "line"
          }
        ]
      }
    }
  ],
  "layout_type": "ordered"
}
